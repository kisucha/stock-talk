# 원격 MariaDB 접속 정보
DB_HOST=192.168.20.80
DB_PORT=3306
DB_USER=root
DB_PASSWORD=740923aa
DB_NAME=stock_analysis

# Ollama API (로컬)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

# SearXNG 인터넷 검색 (사내 서버) — 폴백 검색엔진
SEARXNG_URL=http://192.168.20.80:8080

# Perplexica 답변 엔진 (1순위) — 80서버 docker compose 배포. 실패 시 SearXNG로 자동 폴백.
# infra/perplexica/docker-compose.yml + infra/GUIDE.md 참조.
PERPLEXICA_URL=http://192.168.20.80:3000

# Claude API (Anthropic) — 없으면 앱은 정상 기동, Claude 탭만 안내 메시지
CLAUDE_API_KEY=여기에입력
CLAUDE_MODEL=claude-sonnet-4-6

# 앱 설정
MAX_HISTORY_OLLAMA=20
MAX_HISTORY_CLAUDE=40

# KRX 데이터 포털 (data.krx.co.kr) — get_market_ohlcv_by_ticker 배치 API 로그인용
KRX_ID=krx아이디
KRX_PW=krx비밀번호

# 키움 OpenAPI+ 실시간 거래 (3.5단계)
KIWOOM_ACCOUNT_NO=계좌번호입력
KIWOOM_ACCOUNT_PW=비밀번호입력
KIWOOM_IS_MOCK=true
KIWOOM_BRIDGE_PORT=5001

# 증분 업데이트 Python 실행 경로 (기본: python)
COLLECTOR_PYTHON=python
