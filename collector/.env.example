# ============================================================
# 데이터 수집기 환경 변수 템플릿
# 실제 사용 시 .env로 복사 후 값 채우기. chmod 600 권장.
# ============================================================

# ---------- MariaDB 접속 ----------
# 동일 서버 실행 시 127.0.0.1 권장 (네트워크 우회)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stock_analysis

# ---------- 수집 동작 ----------
# 종목 간 대기 시간(초) — KRX rate limit 회피용
SLEEP_BETWEEN_TICKERS=0.3
# 초기 적재 기간(년)
INIT_YEARS=5
# 영업일 체크 시 fail-safe: 영업일이 아니면 0으로 종료
SKIP_NON_BUSINESS_DAY=true
# 종목별 실패 재시도 횟수
MAX_RETRY=3

# ---------- 로깅 ----------
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 로그 보관 일수
LOG_RETENTION_DAYS=30

# ---------- 텔레그램 알림 ----------
# 비워두면 알림 비활성 (앱은 정상 동작)
# 봇 생성: @BotFather → /newbot → 토큰 발급
# CHAT_ID 확인: 봇과 대화 후 https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- 경로 ----------
# 로그/상태 디렉토리 (절대경로 권장)
LOG_DIR=/opt/stock-collector/logs
STATE_DIR=/opt/stock-collector/state
